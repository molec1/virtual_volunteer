<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Cards -->
    <style name="Widget.VirtualVolunteer.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface_white</item>
    </style>

    <!-- Primary: accent fill, white label, pill -->
    <style name="Widget.VirtualVolunteer.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_pink</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/button_corner_full</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Secondary: white surface, outline, dark text -->
    <style name="Widget.VirtualVolunteer.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/text_secondary</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/surface_white</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/button_corner_full</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.VirtualVolunteer.ScreenTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VirtualVolunteer.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VirtualVolunteer.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VirtualVolunteer.Meta" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.VirtualVolunteer.SectionLabel" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VirtualVolunteer.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.VirtualVolunteer.FinishHighlight" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/accent_pink</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
