<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="3dp">

    <ImageView
        android:id="@+id/thumbImage"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_placeholder_photo"
        android:contentDescription="@string/race_event_photo_thumb_cd"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/finishBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:background="@color/purple_primary_dark"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="@string/race_event_photo_finish_badge"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:visibility="gone"
        tools:visibility="visible" />
</FrameLayout>
