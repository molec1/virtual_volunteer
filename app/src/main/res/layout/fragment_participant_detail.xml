<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="12dp"
        android:paddingBottom="28dp">

        <ImageView
            android:id="@+id/participantDetailThumbnail"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_placeholder_photo"
            android:contentDescription="@string/participant_thumb_cd"
            android:scaleType="centerCrop"
            tools:ignore="ImageContrastCheck" />

        <TextView
            android:id="@+id/participantDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_medium"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Title"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/participantDetailId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
            tools:text="ID: 123" />

        <TextView
            android:id="@+id/participantDetailScanCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
            tools:text="Scan: ABC123" />

        <TextView
            android:id="@+id/racesListHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_large"
            android:text="@string/participant_detail_races_header"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/participantRacesRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:paddingTop="@dimen/list_content_padding"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_participant_detail_race_row"
                    tools:visibility="visible" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>