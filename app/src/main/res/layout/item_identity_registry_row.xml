<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.VirtualVolunteer.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/list_content_padding"
    android:layout_marginVertical="@dimen/list_content_padding">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/registryRowMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:padding="@dimen/card_padding">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/registryThumb"
            android:layout_width="0dp"
            android:layout_height="@dimen/identity_registry_card_thumb_height"
            android:background="@drawable/bg_placeholder_photo"
            android:contentDescription="@string/participant_thumb_cd"
            android:padding="@dimen/face_thumb_inner_padding"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.VirtualVolunteer.RoundedThumb"
            tools:ignore="ImageContrastCheck" />

        <ImageButton
            android:id="@+id/btnDeleteIdentity"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_photo_overlay_icon_circle"
            android:contentDescription="@string/btn_delete_identity_cd"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_delete"
            app:layout_constraintBottom_toBottomOf="@+id/registryThumb"
            app:layout_constraintEnd_toEndOf="@+id/registryThumb"
            android:layout_marginBottom="6dp"
            android:layout_marginEnd="6dp"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/registryIdText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_medium"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/registryThumb"
            tools:text="id=42" />

        <TextView
            android:id="@+id/registryScanText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/text_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/registryIdText"
            tools:text="CODE123" />

        <TextView
            android:id="@+id/registryNotesText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/registryScanText"
            tools:text="Notes"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/registryCreatedText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/registryNotesText"
            tools:text="Created …" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>