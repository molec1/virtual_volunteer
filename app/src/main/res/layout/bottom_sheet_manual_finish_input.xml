<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_white"
    android:orientation="vertical"
    android:padding="@dimen/screen_horizontal_padding">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/manual_finish_sheet_title"
        android:textAppearance="@style/TextAppearance.VirtualVolunteer.ScreenTitle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_spacing_medium"
        android:text="@string/manual_finish_participant_label"
        android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/participantIdLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/participantIdInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/manual_finish_participant_hint"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_spacing_large"
        android:text="@string/manual_finish_time_label"
        android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelectFinishPhoto"
        style="@style/Widget.VirtualVolunteer.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/manual_finish_select_photo" />

    <LinearLayout
        android:id="@+id/groupPhotoTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/textSelectedPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.TitleMedium"
            tools:text="Selected Photo: my_cool_photo.jpg" />

        <TextView
            android:id="@+id/textSelectedPhotoTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
            tools:text="Time from photo: 2026-04-20 10:30:00" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/groupManualTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickDate"
            style="@style/Widget.VirtualVolunteer.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/manual_finish_pick_date" />

        <TextView
            android:id="@+id/textManualDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.TitleMedium"
            tools:text="Date: 2026-04-20" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickTime"
            style="@style/Widget.VirtualVolunteer.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/manual_finish_pick_time" />

        <TextView
            android:id="@+id/textManualTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.TitleMedium"
            tools:text="Time: 10:30:00" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmManualFinish"
        style="@style/Widget.VirtualVolunteer.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_spacing_large"
        android:text="@string/action_confirm" />

</LinearLayout>