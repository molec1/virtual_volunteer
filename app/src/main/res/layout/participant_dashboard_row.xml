<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.VirtualVolunteer.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/list_content_padding"
    android:layout_marginVertical="@dimen/list_content_padding"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/participantThumb"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_placeholder_photo"
            android:contentDescription="@string/participant_thumb_cd"
            android:scaleType="centerCrop"
            tools:ignore="ImageContrastCheck" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/section_spacing_medium"
            android:orientation="vertical">

            <TextView
                android:id="@+id/participantRank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/accent_pink"
                android:visibility="gone"
                tools:text="#3"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/participantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                tools:text="Participant Name" />

            <TextView
                android:id="@+id/participantScanCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
                tools:text="Scan: ABC123" />

            <TextView
                android:id="@+id/participantFinishTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
                tools:text="Finish: 00:00:00" />

            <TextView
                android:id="@+id/participantMovingTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:visibility="gone"
                tools:text="Moving: 00:00"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/participantRegistryInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
                android:visibility="gone"
                tools:text="Registry info"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="@dimen/section_spacing_medium">

            <ImageButton
                android:id="@+id/btnScanCode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_scan_code_cd"
                android:src="@drawable/ic_scan_code"
                app:tint="@color/accent_pink" />

            <ImageButton
                android:id="@+id/btnRemoveParticipant"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_remove_participant_cd"
                android:src="@drawable/ic_delete"
                app:tint="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>