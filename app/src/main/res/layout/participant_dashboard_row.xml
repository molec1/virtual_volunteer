<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.VirtualVolunteer.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <ImageView
            android:id="@+id/participantThumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bg_placeholder_photo"
            android:contentDescription="@string/participant_thumb_cd"
            android:scaleType="centerCrop"
            tools:ignore="ImageContrastCheck" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/section_spacing_medium"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/participantFinishRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="8dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    android:textColor="@color/secondary_ui"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="#1"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/participantHeadline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Name or tap to add" />
            </LinearLayout>

            <TextView
                android:id="@+id/participantFinishTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.FinishHighlight"
                tools:text="Finish: …" />

            <TextView
                android:id="@+id/participantMovingTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/secondary_ui"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Moving: 12:34"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/participantEmbeddingDigest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
                tools:text="Embedding…" />

            <TextView
                android:id="@+id/participantRegistryInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
                android:visibility="gone"
                tools:text="Registry info"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/participantScannedPayload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
                android:visibility="gone"
                tools:text="Scan: …"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnScanCode"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_scan_code_cd"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/accent_pink" />

            <ImageButton
                android:id="@+id/btnRemoveParticipant"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_remove_participant_cd"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
