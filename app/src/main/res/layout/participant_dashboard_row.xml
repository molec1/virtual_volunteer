<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/participantThumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_placeholder_photo"
            android:contentDescription="@string/participant_thumb_cd"
            android:scaleType="centerCrop"
            tools:ignore="ImageContrastCheck" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/participantHashShort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                tools:text="a1b2c3d4…" />

            <TextView
                android:id="@+id/participantDetectedTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                tools:text="Detected: …" />

            <TextView
                android:id="@+id/participantFinishTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                tools:text="Finish: …" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
