<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/embeddingPreviewImage"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:background="@drawable/bg_placeholder_photo"
        android:contentDescription="@string/participant_embedding_preview_cd"
        android:scaleType="centerCrop"
        tools:ignore="ImageContrastCheck" />

    <TextView
        android:id="@+id/embeddingPreviewCaption"
        android:layout_width="96dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_horizontal"
        android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
        tools:text="Start\nRace abcdef12…" />

</LinearLayout>
