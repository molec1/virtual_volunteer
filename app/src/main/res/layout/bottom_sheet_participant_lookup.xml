<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_white"
    android:orientation="vertical"
    android:padding="@dimen/screen_horizontal_padding">

    <TextView
        android:id="@+id/lookupSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/participant_lookup_sheet_title"
        android:textAppearance="@style/TextAppearance.VirtualVolunteer.ScreenTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelectLookupPhoto"
        style="@style/Widget.VirtualVolunteer.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_spacing_medium"
        android:text="@string/participant_lookup_select_photo" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_spacing_medium"
        android:minHeight="120dp">

        <ImageView
            android:id="@+id/lookupPhotoPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:background="@drawable/bg_placeholder_photo"
            android:contentDescription="@string/participant_lookup_select_photo"
            android:maxHeight="240dp"
            android:scaleType="fitCenter"
            tools:ignore="ImageContrastCheck" />

        <TextView
            android:id="@+id/lookupPhotoEmptyHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="16dp"
            android:text="@string/participant_lookup_empty"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta" />
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lookupResultsRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_spacing_medium"
        android:nestedScrollingEnabled="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:itemCount="3"
        tools:listitem="@layout/item_participant_lookup_result"
        tools:visibility="visible" />

</LinearLayout>