<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="12dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/raceIdText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.ScreenTitle"
            tools:text="Race id" />

        <TextView
            android:id="@+id/createdText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
            tools:text="Created: ..." />

        <TextView
            android:id="@+id/locationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
            tools:text="Location: ..." />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
            tools:text="Status: ..." />

        <LinearLayout
            android:id="@+id/timerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="@dimen/section_spacing_medium"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_label"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/timerValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/accent_pink"
                tools:text="00:00" />
        </LinearLayout>

        <!-- Before start -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreStartPhoto"
            style="@style/Widget.VirtualVolunteer.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_large"
            android:text="@string/btn_pre_start_photo" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartRace"
            style="@style/Widget.VirtualVolunteer.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/btn_start_race" />

        <LinearLayout
            android:id="@+id/postStartGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/section_spacing_medium"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTakeFinishPhoto"
                style="@style/Widget.VirtualVolunteer.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_take_finish_photo" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinishRace"
                style="@style/Widget.VirtualVolunteer.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_finish_race" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddManualFinish"
                style="@style/Widget.VirtualVolunteer.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_add_manual_finish" />

        </LinearLayout>

        <!-- Export -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/section_spacing_large"
            android:text="@string/race_detail_section_export"
            android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            style="@style/Widget.VirtualVolunteer.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/btn_export_results" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportTimesCsv"
            style="@style/Widget.VirtualVolunteer.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/btn_export_times_csv" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportParticipantsCsv"
            style="@style/Widget.VirtualVolunteer.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/btn_export_participants_csv" />

        <!-- Offline -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/offlineTestCard"
            style="@style/Widget.VirtualVolunteer.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/offlineTestHeaderLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/offlineTestHeader"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/offline_test_header"
                        android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel" />

                    <ImageView
                        android:id="@+id/offlineTestExpandIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/expand_collapse_cd"
                        android:src="@drawable/ic_chevron_up" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/offlineTestContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/card_padding"
                    android:paddingBottom="@dimen/card_padding">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImportStartPhotos"
                        style="@style/Widget.VirtualVolunteer.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/btn_import_start_photos" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImportFinishPhotos"
                        style="@style/Widget.VirtualVolunteer.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/btn_import_finish_photos" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBuildTestProtocol"
                        style="@style/Widget.VirtualVolunteer.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/btn_build_test_protocol" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTestSingleFinishPhoto"
                        style="@style/Widget.VirtualVolunteer.Button.Secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/btn_test_single_finish_photo" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/participantsCard"
            style="@style/Widget.VirtualVolunteer.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/participantsHeaderLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/dashboardParticipantsTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dashboard_participants_title"
                        android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <ImageView
                        android:id="@+id/participantsExpandIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/expand_collapse_cd"
                        android:src="@drawable/ic_chevron_up" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/participantsContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/card_padding"
                    android:paddingBottom="@dimen/card_padding">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/participantsRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingTop="@dimen/list_content_padding"
                        android:paddingBottom="@dimen/list_content_padding"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:itemCount="4"
                        tools:listitem="@layout/participant_dashboard_row"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pipelineDebugCard"
            style="@style/Widget.VirtualVolunteer.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing_medium">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pipelineDebugHeaderLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/pipelineDebugTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pipeline_debug_title"
                        android:textAppearance="@style/TextAppearance.VirtualVolunteer.SectionLabel" />

                    <ImageView
                        android:id="@+id/pipelineDebugExpandIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/expand_collapse_cd"
                        android:src="@drawable/ic_chevron_up" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pipelineDebugContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/card_padding"
                    android:paddingBottom="@dimen/card_padding">

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fillViewport="false"
                        android:maxHeight="160dp"
                        android:nestedScrollingEnabled="false"
                        android:scrollbars="vertical">

                        <TextView
                            android:id="@+id/pipelineDebugText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/text_secondary"
                            android:textIsSelectable="true"
                            android:textSize="11sp"
                            tools:text="Pipeline log…" />
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>