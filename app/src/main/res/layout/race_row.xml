<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.VirtualVolunteer.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/list_content_padding"
    android:layout_marginVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/raceStartThumb"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/section_spacing_medium"
            android:background="@drawable/bg_placeholder_photo"
            android:contentDescription="@string/race_list_start_thumb_cd"
            android:padding="@dimen/face_thumb_inner_padding"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.VirtualVolunteer.RoundedThumb"
            tools:ignore="ImageContrastCheck"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/raceRowMain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/raceDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Title"
                tools:text="2026-04-18" />

            <TextView
                android:id="@+id/raceTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Meta"
                tools:text="14:32:10" />

            <TextView
                android:id="@+id/raceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@android:color/transparent"
                android:textAppearance="@style/TextAppearance.VirtualVolunteer.Caption"
                android:textColor="@color/secondary_ui"
                tools:text="CREATED" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDeleteRace"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_delete_race_cd"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/text_secondary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
